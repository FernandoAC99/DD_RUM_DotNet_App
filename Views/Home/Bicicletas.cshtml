@{
    ViewData["Title"] = "Reportes de Bicicletas";
}

<div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
        <a href="/Home/Dashboard" class="text-orange-600 hover:underline">← Volver al Panel</a>
        <h1 class="text-3xl font-bold text-slate-800">🚲 Gestión de Bicicletas</h1>
    </div>

    <div class="bg-orange-50 border-l-8 border-orange-500 p-6 rounded-r-xl mb-6">
        <h2 class="font-bold text-orange-800 uppercase tracking-widest text-sm">Estado de Privacidad</h2>
        <p class="text-orange-700 font-medium">Zona de baja prioridad: Datadog Replay debería estar <span class="underline">APAGADO</span> aquí.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full">
            <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase">Marca</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase">Color</th>
                    <th class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase">Estado</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <tr>
                    <td class="px-6 py-4 font-medium">Specialized Rockhopper</td>
                    <td class="px-6 py-4 text-slate-600">Rojo Mate</td>
                    <td class="px-6 py-4"><span class="px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs">Buscando</span></td>
                </tr>
                <tr>
                    <td class="px-6 py-4 font-medium">Trek Marlin 7</td>
                    <td class="px-6 py-4 text-slate-600">Azul Eléctrico</td>
                    <td class="px-6 py-4"><span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs">Recuperada</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>