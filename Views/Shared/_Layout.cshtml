<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Seguridad RUM App</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <header>
        <nav class="bg-slate-900 p-4 text-white flex justify-between items-center shadow-lg">
            <span class="font-bold tracking-wider text-xl">🛡️ SECURITY-NET</span>
            <div>
                @if (Context.Session.GetString("UsuarioLogueado") != null)
                {
                    <span class="text-slate-400 mr-4">User: <b class="text-white">@Context.Session.GetString("UsuarioLogueado")</b></span>
                    <a href="/Home/Logout" class="bg-red-500 hover:bg-red-600 px-3 py-1 rounded text-sm transition">Salir</a>
                }
            </div>
        </nav>
    </header>

    <main class="container mx-auto mt-10 p-4">
        @RenderBody()
    </main>

    <script src="https://www.datadoghq-browser-agent.com/us1/v6/datadog-rum.js" type="text/javascript" crossorigin></script>

<script>
    // 1. Variables de Identidad y Ruta
    const USER_ID = "@Context.Session.GetString("UsuarioLogueado")";
    const CURRENT_PATH = window.location.pathname;

    // 2. Lógica de Tiempo
    const ahora = new Date();
    const hora = ahora.getHours();
    const minutos = ahora.getMinutes();
    
    // Condición: 13:00 a 13:30
    const estaEnRangoHorario = (hora === 13 && minutos >= 0 && minutos <= 40);

    console.log("--- MONITOR DE SEGURIDAD ---");
    console.log(`Hora actual: ${hora}:${minutos < 10 ? '0' + minutos : minutos}`);
    console.log(estaEnRangoHorario ? "✅ Dentro del rango (13:00 - 13:30)" : "❌ Fuera del rango horario");

    // 3. CONDICIÓN MAESTRA: Usuario + Tiempo
    if (USER_ID === "FernandoArteaga99" && estaEnRangoHorario) {
        
        console.log("🚀 Iniciando Datadog RUM: Usuario y Horario validados.");

        window.DD_RUM && window.DD_RUM.init({
            applicationId: '5a827de8-cb36-4cee-b546-14d10f42c015',
            clientToken: 'pub3fce7a4b328a9f262bf1c8f253fa78bb',
            site: 'datadoghq.com',
            service: 'security-app-dotnet',
            env: 'dev',
            version: '1.0.0',
            sessionSampleRate: 100,
            sessionReplaySampleRate: 100,
            trackResources: true,
            trackUserInteractions: true,
            trackLongTasks: true,
            defaultPrivacyLevel: 'allow',
            startSessionReplayRecordingManually: true 
        });

        // 4. LÓGICA DE VISTAS
        if (CURRENT_PATH.includes("Sensible")) {
            window.DD_RUM.startSessionReplayRecording();
            console.warn("🔴 GRABANDO REPLAY: Sección sensible activa.");
        } 
        else if (CURRENT_PATH.includes("Bicicletas")) {
            window.DD_RUM.stopSessionReplayRecording();
            console.info("⚠️ Grabación detenida: Sección Bicicletas.");
        }
        else {
            console.log("⏳ DASHBOARD: RUM activo, Replay pausado.");
        }

        window.DD_RUM.setUser({ id: USER_ID, name: USER_ID, plan: 'admin-test' });

    } else {
        // Explicación de por qué no graba
        if (USER_ID !== "FernandoArteaga99") {
            console.log("⚪ Datadog RUM omitido: El usuario no es FernandoArteaga99.");
        } else if (!estaEnRangoHorario) {
            console.log("⚪ Datadog RUM omitido: Fuera del horario permitido (13:00-13:30).");
        }
    }
</script>
</body>
</html>